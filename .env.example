# Copy to .env and fill in values

# Database — RDS MySQL (ensure host is reachable: security group, VPN). For local-only: DATABASE_URL=sqlite:///./rfp.db

DATABASE_URL= database_url

APP_ENV=development

SECRET_KEY=change-me-in-production

# Field encryption key for api_credentials.secret_key_* (AES-256-GCM).
# Recommended: base64 of 32 random bytes (optionally prefixed with "base64:").
# Example (generate): python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
CREDENTIALS_ENCRYPTION_KEY= credentials_encryption_key

API_V1_PREFIX=/api/v1



# CORS (comma-separated origins)

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000



# Chat completions (search answer, doc metadata, rephrase): Druid gateway

OPENAI_BASE_URL=openai_base_url

OPENAI_API_KEY=openai_api_key



# Embeddings (semantic search): OpenAI API — separate URL and token

OPENAI_EMBEDDING_BASE_URL=https://api.openai.com/v1/embeddings

OPENAI_EMBEDDING_API_KEY=openai_embedding_api_key



OPENAI_EMBEDDING_MODEL=openai_embedding_model

OPENAI_CHAT_MODEL=openai_chat_model

# Set to false if gateway returns 400 (e.g. Druid doesn't support response_format)

# OPENAI_USE_JSON_MODE=false



# PDF OCR (optional — Tesseract must be installed. Set path if not in PATH, e.g. on Windows)

# TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe



# S3 (file storage — files stored at project_id/cluster/filename)

    S3_BUCKET=s3_bucket

AWS_REGION=aws_region

AWS_ACCESS_KEY_ID=aws_access_key_id

AWS_SECRET_ACCESS_KEY=aws_secret_access_key

# SendGrid: create API key at https://app.sendgrid.com; verify SENDGRID_FROM_EMAIL as sender in SendGrid dashboard
SENDGRID_API_KEY=sendgrid_api_key
SENDGRID_FROM_EMAIL=sendgrid_from_email
SENDGRID_FROM_NAME=sendgrid_from_name
FRONTEND_BASE_URL=frontend_base_url
PRODUCT_NAME=product_name
INVITE_TOKEN_HOURS=invite_token_hours
