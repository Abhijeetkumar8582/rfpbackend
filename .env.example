# Copy to .env and fill in values

# Database — RDS MySQL (ensure host is reachable: security group, VPN). For local-only: DATABASE_URL=sqlite:///./rfp.db

DATABASE_URL=db_url
# App

APP_ENV=development

SECRET_KEY=change-me-in-production

API_V1_PREFIX=/api/v1



# CORS (comma-separated origins)

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000



# Chat completions (search answer, doc metadata, rephrase): Druid gateway

OPENAI_BASE_URL=url

OPENAI_API_KEY=openai_key



# Embeddings (semantic search): OpenAI API — separate URL and token

OPENAI_EMBEDDING_BASE_URL=https://api.openai.com/v1/embeddings

OPENAI_EMBEDDING_API_KEY=openai_key

OPENAI_EMBEDDING_MODEL=text-embedding-3-small

OPENAI_CHAT_MODEL=gpt-4o-mini

# Set to false if gateway returns 400 (e.g. Druid doesn't support response_format)

# OPENAI_USE_JSON_MODE=false



# PDF OCR (optional — Tesseract must be installed. Set path if not in PATH, e.g. on Windows)

# TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe



# S3 (file storage — files stored at project_id/cluster/filename)

S3_BUCKET=your-bucket-name

AWS_REGION=us-east-1

AWS_ACCESS_KEY_ID=

AWS_SECRET_ACCESS_KEY=

# SendGrid: create API key at https://app.sendgrid.com; verify SENDGRID_FROM_EMAIL as sender in SendGrid dashboard
SENDGRID_API_KEY=sendgrid_key
SENDGRID_FROM_EMAIL=email
SENDGRID_FROM_NAME=Kiza
FRONTEND_BASE_URL=http://localhost:3000
PRODUCT_NAME=Kiza
INVITE_TOKEN_HOURS=48
